# ─────────────────────────────────────────────
#  VayuSetu — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MySQL Database (must match your local MySQL setup)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=FlightReservation_DbMs

# JWT Secret (change this to a long random string in production)
JWT_SECRET=vayusetu_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS — allow your frontend origin (for local dev use *)
FRONTEND_ORIGIN=*
